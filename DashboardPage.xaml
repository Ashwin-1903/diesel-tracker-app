<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DieselTrackerApp.DashboardPage"
             BackgroundColor="#0D1117">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Label Text="Dashboard"
                   FontSize="28"
                   TextColor="White"
                   FontAttributes="Bold"/>

            <Frame BackgroundColor="#161B22" CornerRadius="15" Padding="15">
                <Button Text="Diesel Tracker"
                        Clicked="OnDieselClicked"/>
            </Frame>

            <Frame BackgroundColor="#161B22" CornerRadius="15" Padding="15">
                <Button Text="History"
                        Clicked="OnHistoryClicked"/>
            </Frame>

            <Button Text="Logout"
                    Clicked="OnLogoutClicked"
                    BackgroundColor="Red"
                    TextColor="White"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>