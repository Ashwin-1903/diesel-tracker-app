<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DieselTrackerApp.HistoryPage"
             BackgroundColor="#121212">

    <CollectionView x:Name="historyList">

        <CollectionView.ItemTemplate>
            <DataTemplate>

                <Frame Margin="10"
                       Padding="12"
                       BackgroundColor="#1E1E1E"
                       CornerRadius="15">

                    <VerticalStackLayout Spacing="5">

                        <Label Text="{Binding Vehicle}"
                               FontSize="18"
                               TextColor="LightGreen"/>

                        <Label Text="{Binding Distance, StringFormat='Distance: {0} km'}"
                               TextColor="White"/>

                        <Label Text="{Binding Road, StringFormat='Road: {0}'}"
                               TextColor="White"/>

                        <Label Text="{Binding Driver, StringFormat='Driver: {0}'}"
                               TextColor="White"/>

                        <Label Text="{Binding Diesel, StringFormat='Diesel: {0:F2} L'}"
                               TextColor="Yellow"/>

                        <Label Text="{Binding Date}"
                               FontSize="12"
                               TextColor="Gray"/>

                    </VerticalStackLayout>

                </Frame>

            </DataTemplate>
        </CollectionView.ItemTemplate>

    </CollectionView>

</ContentPage>